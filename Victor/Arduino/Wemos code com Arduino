#include <SoftwareSerial.h>

#define TX_PIN 13  // D6
#define RX_PIN 12  // D7

SoftwareSerial mySerial(RX_PIN, TX_PIN);  // RX, TX

void setup() {
    Serial.begin(9600);  // Debugging via USB
    mySerial.begin(9600);  // Communication with Arduino

    Serial.println("Wemos: Ready");
    delay(2000);
}

void loop() {
    // Send a message to the Arduino
    String message = "Hello from Wemos!";
    // mySerial.println(message);
    // Serial.println("Wemos Sent: " + message);
    mySerial.println("LED_ON");
    delay(1000);
    mySerial.println("LED_OFF");
    // mySerial.flush();

    // Check if data is received from Arduino
    if (mySerial.available()) {
        String received = mySerial.readStringUntil('\n');
        received.trim();
        Serial.println("received: " + received);
    }

    delay(1000);  // Wait 1 second
}
